# Monitor Layout
set $monitorOne "HDMI-1"
set $monitorTwo "DP-3"
workspace "1" output $monitorOne
workspace "2" output $monitorOne
workspace "3" output $monitorOne
workspace "4" output $monitorOne
workspace "5" output $monitorOne
workspace "6" output $monitorTwo
workspace "7" output $monitorTwo
workspace "8" output $monitorTwo
workspace "9" output $monitorTwo
workspace "10" output $monitorTwo

# Workspaces
exec --no-startup-id "i3-msg 'workspace 1; append_layout /home/cjordan/.config/i3/alacritty.json'"
exec --no-startup-id "i3-msg 'workspace 2; append_layout /home/cjordan/.config/i3/alacritty.json'"
exec --no-startup-id "i3-msg 'workspace 7; append_layout /home/cjordan/.config/i3/firefox.json'"
exec --no-startup-id "i3-msg 'workspace 10; append_layout /home/cjordan/.config/i3/thunderbird.json'"
exec --no-startup-id "alacritty --config-file /home/cjordan/.config/alacritty/alacritty-new-tmux-session.toml"
exec --no-startup-id "alacritty --config-file /home/cjordan/.config/alacritty/alacritty-new-tmux-session.toml"
exec --no-startup-id firefox
exec --no-startup-id thunderbird
for_window [class="Alacritty" workspace=1] focus ; workspace number 1
for_window [class="org.mozilla.firefox" workspace=7] focus ; workspace number 7
